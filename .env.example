# ==============================
# AI-Interview production .env
# ==============================
# 1. Copy to .env before docker compose up
# 2. Replace every value wrapped in <...>
# 3. SECRET_KEY must be a long random value
# 4. DEEPSEEK_API_KEY must be valid before testing AI interview flows

# ------------------------------
# Startup required
# ------------------------------
ENV=production
PROJECT_NAME=AI-Interview
API_V1_STR=/api/v1
API_PORT=8001
API_LOCAL_PORT=18001
FRONTEND_LOCAL_PORT=13000
ADMIN_LOCAL_PORT=13001
UVICORN_WORKERS=4

# Public origin for user site. Required for production links and frontend callbacks.
FRONTEND_URL=https://<INTERVIEW_DOMAIN>

# Comma-separated production origins. Required for browser CORS in production.
BACKEND_CORS_ORIGINS=https://<INTERVIEW_DOMAIN>,https://<ADMIN_DOMAIN>

# Shared Docker network used by hiremate-caddy, portal, and AI-Interview.
SHARED_CADDY_NETWORK=shared_gateway

# PostgreSQL is required for startup.
POSTGRES_USER=<AI_INTERVIEW_DB_USER>
POSTGRES_PASSWORD=<AI_INTERVIEW_DB_PASSWORD>
POSTGRES_DB=<AI_INTERVIEW_DB_NAME>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis is required for startup, Celery, verification code storage, and async jobs.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<AI_INTERVIEW_REDIS_PASSWORD>

# JWT secret. Must be long, random, and unique per environment.
SECRET_KEY=<GENERATE_A_64_PLUS_CHAR_RANDOM_SECRET>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Client registration mode.
# false: recommended for initial production launch. User enters email+password and is logged in directly.
# true: registration requires email verification code; this needs Redis + Celery + SMTP to be healthy.
AUTH_REQUIRE_EMAIL_VERIFICATION=false

# ------------------------------
# Required for AI core features
# ------------------------------
# Resume parsing, AI interview, Q&A, and SSE evaluation all depend on a working DeepSeek key.
DEEPSEEK_API_KEY=<VALID_DEEPSEEK_API_KEY>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ------------------------------
# Required for first admin init
# ------------------------------
# Used only when running scripts/create_first_admin.py.
# Password must be at least 12 chars and include letters, numbers, and special chars.
INIT_ADMIN_EMAIL=<INITIAL_ADMIN_EMAIL>
INIT_ADMIN_PASSWORD=<INITIAL_ADMIN_PASSWORD>
INIT_ADMIN_FIRST_NAME=AI-Interview
INIT_ADMIN_LAST_NAME=Admin

# ------------------------------
# Required only when email flows are enabled
# ------------------------------
# MAIL_* is not required when AUTH_REQUIRE_EMAIL_VERIFICATION=false and you do not use password-reset / email verification flows.
# But MAIL_PORT must never be left blank in .env, otherwise the backend may fail to parse
# the integer value and the app container can become unhealthy.
# If you are not enabling SMTP yet, keep the safe fallback values below.
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@<PRIMARY_DOMAIN>
MAIL_FROM_NAME=AI-Interview
MAIL_ENCRYPTION=none

# Recommended for waiting-list/admin notification and Swagger contact info.
ADMIN_EMAIL=ops@<PRIMARY_DOMAIN>

# ------------------------------
# Optional
# ------------------------------
USE_HTTP_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=

# Optional. Current deployment can use local uploads without S3.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BUCKET_NAME=
AWS_ENDPOINT=

# Optional. Present in codebase but not required for the current core AI flow.
OPENAI_API_KEY=

# ------------------------------
# Minimum launch set
# ------------------------------
# The following values must be valid before the service can be treated as production-ready:
# ENV
# FRONTEND_URL
# BACKEND_CORS_ORIGINS
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB / POSTGRES_HOST / POSTGRES_PORT
# REDIS_HOST / REDIS_PORT
# SECRET_KEY
# DEEPSEEK_API_KEY
#
# If you will run create_first_admin.py during initialization, also set:
# INIT_ADMIN_EMAIL / INIT_ADMIN_PASSWORD
#
# If you will verify registration/password-reset by email, also set:
# AUTH_REQUIRE_EMAIL_VERIFICATION=true
# MAIL_HOST / MAIL_PORT / MAIL_USERNAME / MAIL_PASSWORD / MAIL_FROM_ADDRESS / MAIL_ENCRYPTION
