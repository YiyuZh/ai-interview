ENV=production
PROJECT_NAME=AI-Interview
API_V1_STR=/api/v1
API_PORT=8001
UVICORN_WORKERS=4

FRONTEND_URL=https://<AI_INTERVIEW_DOMAIN>
BACKEND_CORS_ORIGINS=https://<AI_INTERVIEW_DOMAIN>,https://<AI_INTERVIEW_ADMIN_DOMAIN>

SHARED_CADDY_NETWORK=shared_gateway

POSTGRES_USER=<AI_INTERVIEW_DB_USER>
POSTGRES_PASSWORD=<AI_INTERVIEW_DB_PASSWORD>
POSTGRES_DB=<AI_INTERVIEW_DB_NAME>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<AI_INTERVIEW_REDIS_PASSWORD>

FLOWER_PORT=5555

FRONTEND_VITE_API_BASE_URL=/api/v1
FRONTEND_VITE_API_TIMEOUT=60000
ADMIN_VITE_API_BASE_URL=/api/v1/backoffice
ADMIN_VITE_API_TIMEOUT=30000

USE_HTTP_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=

MAIL_MAILER=smtp
MAIL_HOST=<SMTP_HOST>
MAIL_PORT=<SMTP_PORT>
MAIL_USERNAME=<SMTP_USERNAME>
MAIL_PASSWORD=<SMTP_PASSWORD>
MAIL_FROM_ADDRESS=noreply@<PRIMARY_DOMAIN>
MAIL_FROM_NAME=AI-Interview
MAIL_ENCRYPTION=tls

BREVO_API_KEY=<BREVO_API_KEY>
BREVO_EMAIL_FROM=noreply@<PRIMARY_DOMAIN>
BREVO_EMAIL_FROM_NAME=AI-Interview

ADMIN_EMAIL=admin@<PRIMARY_DOMAIN>

SECRET_KEY=<REPLACE_WITH_A_LONG_RANDOM_SECRET>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

AWS_ACCESS_KEY_ID=<AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<AWS_SECRET_ACCESS_KEY>
AWS_REGION=<AWS_REGION>
AWS_BUCKET_NAME=<AWS_BUCKET_NAME>
AWS_ENDPOINT=<AWS_ENDPOINT>

OPENAI_API_KEY=<OPENAI_API_KEY>

DEEPSEEK_API_KEY=<DEEPSEEK_API_KEY>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
