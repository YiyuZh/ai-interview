# 环境配置
ENV=development
PROJECT_NAME=AI-Interview
API_V1_STR=/api/v1
API_PORT=8006

# 数据库配置
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo123
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=ai_interview

# PostgreSQL 连接池配置。小型服务器不要盲目放大 workers 和连接池。
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_SCHEDULER_POOL_SIZE=2
DB_SCHEDULER_MAX_OVERFLOW=3

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6382
REDIS_PASSWORD=

# HTTP 代理配置（一般不需要开启）
USE_HTTP_PROXY=false
HTTP_PROXY=
HTTPS_PROXY=

# 邮件配置（当前未启用，保留默认即可）
MAIL_MAILER=smtp
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=user
MAIL_PASSWORD=password
MAIL_FROM_ADDRESS=noreply@ai-interview.com
MAIL_FROM_NAME=AI-Interview
MAIL_ENCRYPTION=none

# Brevo 邮件服务（当前未启用）
BREVO_API_KEY=dummy-api-key
BREVO_EMAIL_FROM=noreply@ai-interview.com
BREVO_EMAIL_FROM_NAME=AI-Interview

# 管理员邮箱
ADMIN_EMAIL=autsky6666@gmail.com

# Resume OCR fallback. Normal text PDFs do not need this enabled.
ENABLE_RESUME_OCR=false

# JWT 配置
SECRET_KEY=ai-interview-dev-secret-key-2026
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 配置（当前未启用，使用本地存储）
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=your-bucket
AWS_ENDPOINT=https://s3.amazonaws.com

# OpenAI 配置（可作为 embedding 兜底）
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2-chat-latest
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_FINE_TUNE_BASE_MODEL=
OPENAI_FINE_TUNE_SUFFIX=zhiqi-sft

# DeepSeek AI 配置（必填）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_EMBEDDING_MODEL=
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=high
